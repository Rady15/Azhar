    "item": [
        {
            "name": "Login",
            "request": {
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"admin@azhar.com\",\n  \"password\": \"Admin@123\"\n}",
                    "options": { "raw": { "language": "json" } }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/Account/login",
                    "host": ["{{baseUrl}}"],
                    "path": ["api", "Account", "login"]
                }
            }
        },
        {
            "name": "Get Dashboard Stats",
            "description": "إحصائيات لوحة التحكم الرئيسية - returns collectionRate, pendingComplaints, activeMaintenance, totalTenants, totalHouses",
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/Dashboard",
                    "host": ["{{baseUrl}}"],
                    "path": ["api", "Dashboard"]
                }
            },
            "response": [
                {
                    "name": "Example Response",
                    "body": "{\n  \"collectionRate\": 85.5,\n  \"pendingComplaints\": 3,\n  \"activeMaintenance\": 5,\n  \"totalTenants\": 24,\n  \"totalHouses\": 20\n}"
                }
            ]
        },
